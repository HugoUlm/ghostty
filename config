font-family = MesloLGM Nerd Font
font-size = 16

shell-integration-features = no-cursor,sudo,no-title

theme = basic
background-opacity = .5
background-blur-radius = 10

cursor-style = block
cursor-style-blink = true
adjust-cell-height = 10%

mouse-hide-while-typing = true

window-padding-balance = true
window-save-state = always
macos-titlebar-style = transparent
window-colorspace = "display-p3"

keybind = cmd+n=new_window

keybind = cmd+h=goto_split:left
keybind = cmd+j=goto_split:bottom
keybind = cmd+k=goto_split:top
keybind = cmd+l=goto_split:right

keybind = cmd+a>h=new_split:left
keybind = cmd+a>j=new_split:down
keybind = cmd+a>k=new_split:up
keybind = cmd+a>l=new_split:right
keybind = cmd+a>f=toggle_split_zoom
keybind = cmd+shift+w=close_surface
keybind = cmd+z>h=resize_split:left,50
keybind = cmd+z>j=resize_split:down,50
keybind = cmd+z>k=resize_split:up,50
keybind = cmd+z>l=resize_split:right,50

keybind = cmd+a>n=next_tab
keybind = cmd+a>p=previous_tab

keybind = cmd+r=reload_config

keybind = global:cmd+q=toggle_quick_terminal

keybind = cmd+shift+h=text:cd
keybind = cmd+shift+r=text:cd src/repos/

